{
  "rewrites": [
    { "source": "/api/player", "destination": "/api/extra?route=player" },
    { "source": "/api/transactions", "destination": "/api/extra?route=transactions" },
    { "source": "/api/matchup", "destination": "/api/extra?route=matchup" },
    { "source": "/api/leaders", "destination": "/api/extra?route=leaders" },
    { "source": "/api/league-leaders", "destination": "/api/extra?route=league-leaders" },
    { "source": "/api/highlights", "destination": "/api/extra?route=highlights" },
    { "source": "/api/scoreboard", "destination": "/api/extra?route=scoreboard" },
    { "source": "/api/bvp", "destination": "/api/extra?route=bvp" },
    { "source": "/api/analytics", "destination": "/api/extra?route=analytics" },
    { "source": "/api/situational", "destination": "/api/extra?route=situational" },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
